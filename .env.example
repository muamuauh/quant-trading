# Copy this file to .env and fill in real values.
# These env vars are read by:
#   - the moomoo skill's common.py (FUTU_* prefix is required by the skill)
#   - this project's src/qtf/config.py (mirrors them for type-safe access)

# --- OpenD connection ---
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# --- Account ---
# Run: python C:\Users\gjq00\.claude\skills\moomooapi\scripts\trade\get_accounts.py --json
# Pick a non-MASTER account with trd_env=SIMULATE; copy its acc_id below.
FUTU_ACC_ID=
FUTU_DEFAULT_MARKET=US

# --- Trading env guard ---
# Must be SIMULATE for this skeleton. Setting REAL also requires I_CONFIRM_REAL=1.
FUTU_TRD_ENV=SIMULATE
I_CONFIRM_REAL=0

# --- Skill location (rarely changes) ---
MOOMOO_SKILL_DIR=C:\Users\gjq00\.claude\skills\moomooapi

# ============================================================
# TradingAgents (LLM review layer) — opt-in
# ============================================================
# When 0, qlib's topk weights pass straight to risk gates (legacy behavior).
# When 1, each candidate ticker is re-evaluated by the TradingAgents multi-agent
# graph; only "Buy"/"Overweight" ratings are kept. See src/qtf/agents/review.py.
QTF_AGENTS_ENABLED=0

# Minimum rating to keep a candidate. One of: Buy | Overweight | Hold | Underweight | Sell
# Default "Overweight" means Buy+Overweight pass, anything weaker is dropped.
QTF_AGENTS_MIN_RATING=Overweight

# If 1, when an agent call fails (timeout / API error / no key), keep the candidate
# (fail-open). If 0, drop on failure (fail-closed). Default 1 — LLM problems
# shouldn't block the underlying qlib pipeline.
QTF_AGENTS_FAIL_OPEN=1

# --- LLM provider (read by TradingAgents directly) ---
# Provider: openai | anthropic | google | deepseek | qwen | glm | azure | ollama
TRADINGAGENTS_LLM_PROVIDER=openai
# Two-tier models: heavy reasoning for trader/PM, lightweight for quick checks
TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
# Optional base URL override (point to a self-hosted gateway or alt provider).
# Leave blank for the provider's official endpoint.
TRADINGAGENTS_LLM_BACKEND_URL=
# Cap LLM debate / risk-discussion rounds. Higher = more cost + slightly better
# reasoning. Keep at 1 for daily paper trading.
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1
# Output language for the rationale ("English" or "中文"). Internal debate
# always runs in English for reasoning quality.
TRADINGAGENTS_OUTPUT_LANGUAGE=中文

# --- Provider API keys (only the one matching LLM_PROVIDER is needed) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# DeepSeek example (uncomment & fill to switch):
# TRADINGAGENTS_LLM_PROVIDER=deepseek
# TRADINGAGENTS_DEEP_THINK_LLM=deepseek-chat
# TRADINGAGENTS_QUICK_THINK_LLM=deepseek-chat
# TRADINGAGENTS_LLM_BACKEND_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=sk-xxxxx

